set $mod Mod1
font pango:UbuntuMono Nerd Font 9

exec --no-startup-id dex --autostart --environment i3
exec --no-startup-id xss-lock --transfer-sleep-lock -- i3lock --nofork
exec --no-startup-id nm-applet
exec --no-startup-id xset s off -dpms

bindsym $mod+i exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ +5%
bindsym $mod+o exec --no-startup-id pactl set-sink-volume @DEFAULT_SINK@ -5%
bindsym $mod+m exec --no-startup-id pactl set-sink-mute @DEFAULT_SINK@ toggle
#bindsym $mod+Shift+m exec --no-startup-id pactl set-source-mute @DEFAULT_SOURCE@ toggle

bindsym $mod+d exec --no-startup-id "dmenu_run -nf '#ffffff' -nb '#000000' -sb '#1e1e2e' -sf '#ffffff' -fn 'UbuntuMono Nerd Font-11'"
bindsym $mod+s exec scrot './screenshots/%F-%H%M%S_$wx$h.png' -s

bindsym $mod+Return exec alacritty

bindsym $mod+p exec qutebrowser & $HOME/.config/qutebrowser/clean-up/qutebrowser-cookie-clean-up.sh
bindsym $mod+Shift+p exec qutebrowser --target private-window

bindsym $mod+q kill
bindsym $mod+Shift+r restart
bindsym $mod+Shift+e exec i3 exit


bindsym $mod+h focus left
bindsym $mod+j focus down
bindsym $mod+k focus up
bindsym $mod+l focus right

bindsym $mod+Shift+h move left
bindsym $mod+Shift+j move down
bindsym $mod+Shift+k move up
bindsym $mod+Shift+l move right

bindsym $mod+Ctrl+h resize shrink width 5 px or 5 ppt
bindsym $mod+Ctrl+j resize shrink height 5 px or 5 ppt
bindsym $mod+Ctrl+k resize grow height 5 px or 5 ppt
bindsym $mod+Ctrl+l resize grow width 5 px or 5 ppt

bindsym $mod+f fullscreen toggle
bindsym $mod+v split h
bindsym $mod+c split v


set $ws1 "1:i"
set $ws2 "2:ii"
set $ws3 "3:iii"
set $ws4 "4:iv"
set $ws5 "5:v"
set $ws6 "6:vi"
set $ws7 "7:vii"
set $ws8 "8:viii"
set $ws9 "9:ix"
set $ws10 "10:x"

bindsym $mod+1 workspace number $ws1
bindsym $mod+2 workspace number $ws2
bindsym $mod+3 workspace number $ws3
bindsym $mod+4 workspace number $ws4
bindsym $mod+5 workspace number $ws5
bindsym $mod+6 workspace number $ws6
bindsym $mod+7 workspace number $ws7
bindsym $mod+8 workspace number $ws8
bindsym $mod+9 workspace number $ws9
bindsym $mod+0 workspace number $ws10

bindsym $mod+Shift+1 move container to workspace number $ws1
bindsym $mod+Shift+2 move container to workspace number $ws2
bindsym $mod+Shift+3 move container to workspace number $ws3
bindsym $mod+Shift+4 move container to workspace number $ws4
bindsym $mod+Shift+5 move container to workspace number $ws5
bindsym $mod+Shift+6 move container to workspace number $ws6
bindsym $mod+Shift+7 move container to workspace number $ws7
bindsym $mod+Shift+8 move container to workspace number $ws8
bindsym $mod+Shift+9 move container to workspace number $ws9
bindsym $mod+Shift+0 move container to workspace number $ws10


# class                 border  bground text    indicator child_border
client.focused          #ffc5d3 #ffc5d3 #ffffff #ffc5d3   #ffc5d3
client.focused_inactive #000000 #000000 #ffffff #000000   #000000
client.unfocused        #000000 #000000 #ffffff #000000   #000000
client.urgent           #ffff99 #ffff99 #ffffff #ffff99   #ffff99
client.placeholder      #000000 #000000 #ffffff #000000   #000000
client.background       #ffffff

#hide title bar
default_border pixel 1
default_floating_border pixel 1
for_window [class="^.*"] border pixel 1


bindsym $mod+b exec $HOME/.config/i3/polybar/swap.sh

exec_always --no-startup-id feh --bg-scale $HOME/.config/i3/wallpapers/faye.png
exec_always --no-startup-id $HOME/.config/i3/polybar/launch.sh
